# ─── Database ────────────────────────────────────────────────────────────────
# Local (Docker / local Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/task_manager

# Production (Supabase)
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?ssl=require

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
# Production: CORS_ORIGINS=https://your-app.vercel.app

PORT=8000
TZ=Asia/Kolkata